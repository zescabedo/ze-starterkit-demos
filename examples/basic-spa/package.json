{
  "name": "xmcloud-foundation",
  "private": true,
  "version": "22.7.0",
  "description": "This repository contains the Starter Kits for Sitecore XM Cloud Development.",
  "scripts": {
    "install-build:angular": "pnpm install && pnpm build:angular",
    "build:angular": "pnpm -F=angular-starter build",
    "start:angular": "pnpm -F=node-xmcloud-sample start"
  },
  "license": "ISC",
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.11.0"
  },
  "pnpm": {
    "overrides": {
      "@angular/compiler": "20.3.18",
      "@angular/core": "20.3.18",
      "picomatch": "4.0.4",
      "anymatch>picomatch": "2.3.2",
      "micromatch>picomatch": "2.3.2",
      "node-forge": "1.4.0",
      "brace-expansion@^5.0.0": "5.0.5",
      "serialize-javascript": "7.0.5",
      "flatted": "3.4.2",
      "express>path-to-regexp": "0.1.13",
      "qs": "6.14.2",
      "vite": "7.3.2",
      "lodash": "4.18.1"
    }
  }
}
